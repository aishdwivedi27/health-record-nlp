# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Database Configuration
# SQLite for development
DATABASE_URL=sqlite:///./ehr.db

# PostgreSQL for production (uncomment and update)
# DATABASE_URL=postgresql://user:password@localhost:5432/ehr_poc

# Server Configuration
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# NLP Configuration
# Model options: claude-opus-4-1, claude-3-sonnet, claude-3-haiku
NLP_MODEL=claude-opus-4-1

# Query Limits
# Maximum days to look back in queries
NLP_MAX_DAYS_BACK=90

# Maximum records to return per query
NLP_MAX_RECORDS=50

# Enable debug logging
DEBUG=false
